{
  "name": "alpine-mcp",
  "version": "1.0.3",
  "description": "MCP server providing Alpine.js documentation and reference",
  "repository": {
    "type": "git",
    "url": "https://github.com/BillyNoyes/alpine-mcp"
  },
  "type": "module",
  "bin": {
    "alpine-mcp": "build/index.js"
  },
  "scripts": {
    "generate": "node --import tsx/esm scripts/generate.ts",
    "build": "npm run generate && vite build && chmod 755 build/index.js",
    "build:no-generate": "vite build && chmod 755 build/index.js",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.0.0",
    "vite": "^5.0.0",
    "tsx": "^4.0.0"
  }
}
